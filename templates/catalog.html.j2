<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ brand }}</title>
<style>
  :root {
    --accent: {{ color }};
    --accent-ink: #ffffff;
    --bg:      #f7f4f1;
    --surface: #ffffff;
    --ink:     #241f1e;
    --muted:   #8a807b;
    --line:    #e9e2dc;
    --chip:    #efeae5;
    --ok:   #1f8f57;
    --pre:  #2563c4;
    --soon: #c07a12;
  }
  @media (prefers-color-scheme: dark) {
    :root { --bg:#17140f; --surface:#211c18; --ink:#f2ede8; --muted:#a89c93; --line:#322a24; --chip:#2b241f; }
  }
  :root[data-theme="dark"]  { --bg:#17140f; --surface:#211c18; --ink:#f2ede8; --muted:#a89c93; --line:#322a24; --chip:#2b241f; }
  :root[data-theme="light"] { --bg:#f7f4f1; --surface:#ffffff; --ink:#241f1e; --muted:#8a807b; --line:#e9e2dc; --chip:#efeae5; }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: "Segoe UI", -apple-system, Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg); color: var(--ink); -webkit-font-smoothing: antialiased;
  }
  header {
    background: var(--accent); color: var(--accent-ink);
    padding: 20px 16px; text-align: center;
  }
  .brand {
    font-family: "Hoefler Text", Georgia, "Times New Roman", serif;
    font-size: 1.7rem; font-weight: 600; letter-spacing: .04em; text-wrap: balance;
  }
  .tagline { font-size: .7rem; text-transform: uppercase; letter-spacing: .22em; opacity: .9; margin-top: 6px; }

  .filters {
    position: sticky; top: 0; z-index: 20; background: var(--bg);
    border-bottom: 1px solid var(--line); padding: 10px 12px;
    display: flex; flex-direction: column; gap: 8px; max-width: 1120px; margin: 0 auto;
  }
  .filters .row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .search {
    flex: 1 1 100%; min-width: 0; padding: 9px 12px; font-size: .9rem;
    border: 1px solid var(--line); border-radius: 10px; background: var(--surface); color: var(--ink);
  }
  select {
    padding: 8px 10px; font-size: .82rem; border: 1px solid var(--line);
    border-radius: 10px; background: var(--surface); color: var(--ink); flex: 1 1 46%;
  }
  .chip {
    font-size: .74rem; font-weight: 600; padding: 6px 12px; border-radius: 999px;
    border: 1px solid var(--line); background: var(--chip); color: var(--ink); cursor: pointer;
  }
  .chip.active { background: var(--accent); color: var(--accent-ink); border-color: var(--accent); }
  .count { font-size: .74rem; color: var(--muted); padding: 0 2px; }

  .grid {
    display: grid; gap: 14px; padding: 14px;
    grid-template-columns: repeat(2, 1fr); max-width: 1120px; margin: 0 auto;
  }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(3, 1fr); gap: 18px; } }
  @media (min-width: 960px) { .grid { grid-template-columns: repeat(4, 1fr); } }
  .card {
    background: var(--surface); border: 1px solid var(--line); border-radius: 12px;
    overflow: hidden; display: flex; flex-direction: column;
    transition: transform .15s ease, box-shadow .15s ease;
  }
  @media (hover: hover) { .card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.10); } }
  .imgwrap { position: relative; aspect-ratio: 4/5; background: var(--line); }
  .carousel {
    display: flex; width: 100%; height: 100%; overflow-x: auto; scroll-snap-type: x mandatory;
    scrollbar-width: none; -webkit-overflow-scrolling: touch;
  }
  .carousel::-webkit-scrollbar { display: none; }
  .carousel img { flex: 0 0 100%; width: 100%; height: 100%; object-fit: cover; scroll-snap-align: center; }
  .nav {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
    width: 30px; height: 30px; border: none; border-radius: 999px; cursor: pointer;
    background: rgba(0,0,0,.5); color: #fff; font-size: 20px; line-height: 1;
    display: flex; align-items: center; justify-content: center;
  }
  .nav.prev { left: 6px; } .nav.next { right: 6px; }
  @media (hover: hover) { .nav:hover { background: rgba(0,0,0,.75); } }
  .dots {
    position: absolute; bottom: 7px; left: 0; right: 0; display: flex; gap: 4px;
    justify-content: center; pointer-events: none;
  }
  .dots i {
    width: 5px; height: 5px; border-radius: 999px; background: rgba(255,255,255,.6);
    box-shadow: 0 0 2px rgba(0,0,0,.5); transition: background .2s;
  }
  .dots i.on { background: #fff; }
  .photocount {
    position: absolute; top: 9px; right: 9px; font-size: .6rem; font-weight: 700;
    padding: 2px 7px; border-radius: 999px; background: rgba(0,0,0,.55); color: #fff;
  }
  .badge {
    position: absolute; top: 9px; left: 9px; font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em; padding: 3px 9px; border-radius: 999px; color: #fff;
  }
  .badge.ok { background: var(--ok); } .badge.pre { background: var(--pre); } .badge.soon { background: var(--soon); }
  .body { padding: 10px 12px 14px; display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .name {
    font-size: .82rem; font-weight: 500; line-height: 1.3;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.15em;
  }
  .price { font-size: 1.12rem; font-weight: 700; color: var(--accent); margin-top: auto; font-variant-numeric: tabular-nums; }
  .wa {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    margin-top: 8px; padding: 8px; border-radius: 9px; text-decoration: none;
    background: #25d366; color: #fff; font-size: .8rem; font-weight: 700;
  }
  .wa svg { width: 15px; height: 15px; fill: currentColor; }
  @media (hover: hover) { .wa:hover { background: #1eb757; } }
  .empty { text-align: center; color: var(--muted); padding: 40px 16px; display: none; }
  footer { text-align: center; font-size: .72rem; color: var(--muted); padding: 26px 16px 40px; border-top: 1px solid var(--line); }
  .carousel img { cursor: zoom-in; }

  /* Visor de fotos con zoom */
  .lb { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,.94); }
  .lb[hidden] { display: none; }
  .lb-stage {
    position: absolute; inset: 0; overflow: hidden; touch-action: none;
    display: flex; align-items: center; justify-content: center;
  }
  .lb-stage img {
    max-width: 100%; max-height: 100%; transform-origin: center center;
    will-change: transform; -webkit-user-select: none; user-select: none; -webkit-user-drag: none;
  }
  .lb-close, .lb-nav {
    position: absolute; z-index: 3; border: none; cursor: pointer; color: #fff;
    background: rgba(255,255,255,.18); border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
  }
  .lb-close { top: 14px; right: 14px; width: 44px; height: 44px; font-size: 26px; }
  .lb-nav { top: 50%; transform: translateY(-50%); width: 46px; height: 46px; font-size: 30px; }
  .lb-prev { left: 12px; } .lb-next { right: 12px; }
  .lb-count {
    position: absolute; top: 18px; left: 0; right: 0; text-align: center; z-index: 3;
    color: #fff; font-size: .82rem; font-weight: 600; pointer-events: none;
  }
  .lb-hint {
    position: absolute; bottom: 22px; left: 0; right: 0; text-align: center; z-index: 3;
    color: rgba(255,255,255,.8); font-size: .78rem; pointer-events: none;
  }
</style>
</head>
<body>
  <header>
    <div class="brand">{{ brand }}</div>
    <div class="tagline">{{ tagline }}</div>
  </header>

  <div class="filters">
    <input id="q" class="search" type="search" placeholder="Buscar producto…" autocomplete="off">
    <div class="row">
      <select id="cat">
        <option value="">Todas las categorías</option>
        {% for c in categories %}<option value="{{ c }}">{{ c }}</option>{% endfor %}
      </select>
      <select id="brand">
        <option value="">Todas las marcas</option>
        {% for b in brands %}<option value="{{ b }}">{{ b }}</option>{% endfor %}
      </select>
    </div>
    <div class="row" id="statusChips">
      <span class="chip active" data-status="">Todos</span>
      {% for s in statuses %}<span class="chip" data-status="{{ s }}">{{ s }}</span>{% endfor %}
    </div>
    <div class="count"><span id="count">{{ count }}</span> productos · Actualizado {{ updated }}</div>
  </div>

  <main class="grid" id="grid">
    {% for p in products %}
    <article class="card" data-name="{{ p.name|lower }}" data-status="{{ p.status }}"
             data-brand="{{ p.brand }}" data-cats="{{ p.categories|join('|') }}">
      <div class="imgwrap">
        <div class="carousel">
          {% for img in p.images %}<img src="{{ img }}" alt="{{ p.name }}" loading="lazy">{% endfor %}
        </div>
        <span class="badge {{ p.status_css }}">{{ p.status }}</span>
        {% if p.images|length > 1 %}
        <button class="nav prev" data-dir="-1" aria-label="Foto anterior">‹</button>
        <button class="nav next" data-dir="1" aria-label="Foto siguiente">›</button>
        <span class="photocount">📷 {{ p.images|length }}</span>
        <div class="dots">{% for img in p.images %}<i></i>{% endfor %}</div>
        {% endif %}
      </div>
      <div class="body">
        <div class="name">{{ p.name }}</div>
        <div class="price">{{ p.price | price }}</div>
        {% if whatsapp %}
        <a class="wa" target="_blank" rel="noopener"
           href="https://wa.me/{{ whatsapp }}?text={{ (whatsapp_msg ~ ' ' ~ p.name ~ ' (' ~ currency ~ ' ' ~ p.price|int ~ ')')|urlencode }}">
          <svg viewBox="0 0 24 24"><path d="M.06 24l1.68-6.1a11.87 11.87 0 01-1.6-5.95C.15 5.35 5.5 0 12.05 0a11.82 11.82 0 018.4 3.5 11.75 11.75 0 013.48 8.4c0 6.55-5.35 11.9-11.9 11.9a11.9 11.9 0 01-5.7-1.45L.06 24zm6.6-3.8c1.7.98 3.2 1.57 5.4 1.57 5.44 0 9.9-4.43 9.9-9.9 0-5.46-4.4-9.9-9.9-9.9-5.47 0-9.9 4.44-9.9 9.9 0 2.3.7 4 1.8 5.68l-1 3.6 3.7-.95zm11.36-5.3c-.07-.12-.27-.2-.57-.35-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.9-.8-1.5-1.77-1.67-2.07-.17-.3-.02-.46.13-.6.13-.14.3-.35.44-.53.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.48-.5-.66-.5l-.57-.02c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.06 2.88 1.2 3.08.15.2 2.1 3.2 5.07 4.5.7.3 1.26.48 1.7.62.7.22 1.35.2 1.86.12.57-.08 1.76-.72 2-1.4.25-.7.25-1.28.18-1.4z"/></svg>
          Pedir por WhatsApp
        </a>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </main>
  <p class="empty" id="empty">No hay productos con esos filtros.</p>

  <div id="lb" class="lb" hidden>
    <span class="lb-count"></span>
    <button class="lb-close" aria-label="Cerrar">×</button>
    <button class="lb-nav lb-prev" aria-label="Foto anterior">‹</button>
    <button class="lb-nav lb-next" aria-label="Foto siguiente">›</button>
    <div class="lb-stage"><img alt=""></div>
    <div class="lb-hint">Pellizca, doble toque o rueda para acercar · desliza para cerrar</div>
  </div>

  <footer>{{ brand }} · Precios en soles, sujetos a disponibilidad</footer>

<script>
(function () {
  var q = document.getElementById('q'),
      cat = document.getElementById('cat'),
      brand = document.getElementById('brand'),
      chips = document.getElementById('statusChips'),
      cards = Array.prototype.slice.call(document.querySelectorAll('.card')),
      countEl = document.getElementById('count'),
      empty = document.getElementById('empty');
  var status = '';

  function apply() {
    var text = q.value.trim().toLowerCase(),
        c = cat.value, b = brand.value, shown = 0;
    cards.forEach(function (card) {
      var ok = (!text || card.dataset.name.indexOf(text) > -1)
            && (!c || ('|' + card.dataset.cats + '|').indexOf('|' + c + '|') > -1)
            && (!b || card.dataset.brand === b)
            && (!status || card.dataset.status === status);
      card.style.display = ok ? '' : 'none';
      if (ok) shown++;
    });
    countEl.textContent = shown;
    empty.style.display = shown ? 'none' : 'block';
  }

  // Puntitos del carrusel: marcar el activo según el desplazamiento
  document.querySelectorAll('.carousel').forEach(function (car) {
    var dots = car.parentElement.querySelectorAll('.dots i');
    if (!dots.length) return;
    car.addEventListener('scroll', function () {
      var idx = Math.round(car.scrollLeft / car.clientWidth);
      dots.forEach(function (d, i) { d.classList.toggle('on', i === idx); });
    }, { passive: true });
    if (dots[0]) dots[0].classList.add('on');
  });

  // Flechas del carrusel: pasar una foto por toque
  document.querySelectorAll('.nav').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var car = btn.parentElement.querySelector('.carousel');
      car.scrollBy({ left: parseInt(btn.dataset.dir, 10) * car.clientWidth, behavior: 'smooth' });
    });
  });

  q.addEventListener('input', apply);
  cat.addEventListener('change', apply);
  brand.addEventListener('change', apply);
  chips.addEventListener('click', function (e) {
    var chip = e.target.closest('.chip');
    if (!chip) return;
    chips.querySelectorAll('.chip').forEach(function (x) { x.classList.remove('active'); });
    chip.classList.add('active');
    status = chip.dataset.status;
    apply();
  });
})();
</script>

<script>
/* Visor de fotos con zoom (pinch / doble toque / rueda) */
(function () {
  var lb = document.getElementById('lb'),
      stage = lb.querySelector('.lb-stage'),
      img = stage.querySelector('img'),
      countEl = lb.querySelector('.lb-count');
  var group = [], idx = 0, scale = 1, tx = 0, ty = 0;
  var pts = {}, startDist = 0, startScale = 1, startMid = null, startTx = 0, startTy = 0;
  var down = null, moved = false;
  var cx = function () { return window.innerWidth / 2; };
  var cy = function () { return window.innerHeight / 2; };

  function apply() {
    img.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')';
    img.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
  }
  function animate() { img.style.transition = 'transform .15s'; apply(); setTimeout(function () { img.style.transition = ''; }, 170); }
  function show(i) {
    idx = (i + group.length) % group.length;
    img.src = group[idx]; scale = 1; tx = 0; ty = 0; apply();
    countEl.textContent = group.length > 1 ? (idx + 1) + ' / ' + group.length : '';
    lb.querySelector('.lb-prev').style.display = lb.querySelector('.lb-next').style.display = group.length > 1 ? '' : 'none';
  }
  function open(list, i) { group = list; lb.hidden = false; document.documentElement.style.overflow = 'hidden'; show(i); }
  function close() { lb.hidden = true; document.documentElement.style.overflow = ''; }

  // Abrir el visor al tocar una foto
  document.querySelectorAll('.carousel').forEach(function (car) {
    var srcs = Array.prototype.map.call(car.querySelectorAll('img'), function (im) { return im.getAttribute('src'); });
    Array.prototype.forEach.call(car.querySelectorAll('img'), function (im, i) {
      im.addEventListener('click', function (ev) { ev.preventDefault(); ev.stopPropagation(); open(srcs, i); });
    });
  });

  lb.querySelector('.lb-close').addEventListener('click', function (e) { e.stopPropagation(); close(); });
  lb.querySelector('.lb-prev').addEventListener('click', function (e) { e.stopPropagation(); show(idx - 1); });
  lb.querySelector('.lb-next').addEventListener('click', function (e) { e.stopPropagation(); show(idx + 1); });
  document.addEventListener('keydown', function (e) {
    if (lb.hidden) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') show(idx - 1);
    else if (e.key === 'ArrowRight') show(idx + 1);
  });

  function keys() { return Object.keys(pts); }
  function d2(a, b) { return Math.hypot(a.x - b.x, a.y - b.y); }
  function mid2(a, b) { return { x: (a.x + b.x) / 2, y: (a.y + b.y) / 2 }; }

  stage.addEventListener('pointerdown', function (e) {
    stage.setPointerCapture(e.pointerId);
    pts[e.pointerId] = { x: e.clientX, y: e.clientY };
    moved = false; down = { x: e.clientX, y: e.clientY, tx: tx, ty: ty };
    var k = keys();
    if (k.length === 2) {
      startDist = d2(pts[k[0]], pts[k[1]]); startScale = scale;
      startMid = mid2(pts[k[0]], pts[k[1]]); startTx = tx; startTy = ty;
    }
  });
  stage.addEventListener('pointermove', function (e) {
    if (!pts[e.pointerId]) return;
    pts[e.pointerId] = { x: e.clientX, y: e.clientY };
    var k = keys();
    if (k.length >= 2) {
      moved = true;
      var d = d2(pts[k[0]], pts[k[1]]), m = mid2(pts[k[0]], pts[k[1]]);
      scale = Math.min(5, Math.max(1, startScale * (d / startDist)));
      tx = startTx + (m.x - startMid.x); ty = startTy + (m.y - startMid.y);
      apply();
    } else if (scale > 1 && down) {
      if (Math.abs(e.clientX - down.x) + Math.abs(e.clientY - down.y) > 4) moved = true;
      tx = down.tx + (e.clientX - down.x); ty = down.ty + (e.clientY - down.y); apply();
    } else if (down) {
      if (Math.abs(e.clientX - down.x) + Math.abs(e.clientY - down.y) > 8) moved = true;
    }
  });
  function endPointer(e) {
    var startX = down ? down.x : e.clientX;
    delete pts[e.pointerId];
    if (keys().length === 0) {
      if (scale < 1.05) { // no hay zoom: gesto de deslizar/tap
        if (moved) {
          var dx = e.clientX - startX, dy = e.clientY - (down ? down.y : e.clientY);
          if (Math.abs(dx) > 60 && Math.abs(dx) > Math.abs(dy) && group.length > 1) show(idx + (dx < 0 ? 1 : -1));
          else if (Math.abs(dy) > 80) close();  // deslizar para cerrar
        } else {
          tap(e);
        }
      }
      down = null;
    }
  }
  stage.addEventListener('pointerup', endPointer);
  stage.addEventListener('pointercancel', function (e) { delete pts[e.pointerId]; if (!keys().length) down = null; });

  function tap(e) {
    if (e.target !== img) { close(); return; }  // tocar el fondo cierra
    if (scale > 1) { scale = 1; tx = 0; ty = 0; }
    else { scale = 2.5; var ox = e.clientX - cx(), oy = e.clientY - cy(); tx = ox * (1 - scale); ty = oy * (1 - scale); }
    animate();
  }

  stage.addEventListener('wheel', function (e) {
    e.preventDefault();
    var ns = Math.min(5, Math.max(1, scale * (e.deltaY < 0 ? 1.2 : 0.83)));
    var ox = e.clientX - cx(), oy = e.clientY - cy();
    tx = (tx - ox * (1 - scale)) + ox * (1 - ns);
    ty = (ty - oy * (1 - scale)) + oy * (1 - ns);
    scale = ns; if (scale <= 1.02) { scale = 1; tx = 0; ty = 0; }
    apply();
  }, { passive: false });
})();
</script>
</body>
</html>
